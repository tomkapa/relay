{
  "name": "relay",
  "version": "0.0.0",
  "private": true,
  "description": "Platform for running agents that act on behalf of people, teams, or any group of interests.",
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test",
    "db:migrate": "bun run src/db/migrate-main.ts",
    "check": "bun run lint && bun run fmt:check && bun run typecheck && bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.91.0",
    "@aws-sdk/client-s3": "3.1036.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@noble/ciphers": "2.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "0.215.0",
    "@opentelemetry/auto-instrumentations-node": "0.73.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.215.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.215.0",
    "@opentelemetry/sdk-node": "0.215.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "kysely": "0.28.16",
    "postgres": "^3.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tsconfig/strictest": "^2.0.5",
    "@types/bun": "1.3.13",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "10.2.1",
    "prettier": "^3.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.18.0"
  }
}
