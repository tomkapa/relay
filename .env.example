# Copy to .env for local development. Never commit .env.

# --- Postgres ---
# Source of truth for structured state (SPEC.md §Architecture).
DATABASE_URL=postgres://relay:relay@localhost:5432/relay

# --- Redis ---
# Ephemeral runtime state only: leases, locks, rate counters. Never source of truth.
REDIS_URL=redis://localhost:6379/0

# --- Object storage (S3-compatible) ---
# MinIO locally, S3 in prod.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=relay-blobs

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# --- OpenTelemetry ---
# CLAUDE.md §2 — OTel is the only instrumentation API.
OTEL_SERVICE_NAME=relay
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# --- Secrets ---
# Master key for at-rest encryption of tenant connector secrets (SPEC.md §Connector state).
# 32 bytes, hex-encoded. Rotate via a migration, not in-place.
SECRETS_MASTER_KEY_HEX=

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=INFO
