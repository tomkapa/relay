# Copy to .env for local development. Never commit .env.

# --- Postgres ---
# Source of truth for structured state (SPEC.md §Architecture).
DATABASE_URL=postgres://relay:relay@localhost:5432/relay

# --- Object storage (S3-compatible) ---
# MinIO locally, S3 in prod.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=relay-blobs

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # override for proxies or local stubs

# --- OpenTelemetry ---
# CLAUDE.md §2 — OTel is the only instrumentation API.
OTEL_SERVICE_NAME=relay
OTEL_RESOURCE_ATTRIBUTES=deployment.environment.name=local

# Local collector (debug exporter, prints to stdout). Use for offline dev:
#   docker run --rm -p 4318:4318 -v $(pwd)/config/otel/debug.yaml:/etc/otel/config.yaml \
#     otel/opentelemetry-collector-contrib --config /etc/otel/config.yaml
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Honeycomb (traces + logs — dataset name comes from OTEL_SERVICE_NAME automatically).
# Get your API key at https://ui.honeycomb.io/account.
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-api-key-here

# --- Secrets ---
# Master key for at-rest encryption of tenant connector secrets (SPEC.md §Connector state).
# 32 bytes, hex-encoded. Rotate via a migration, not in-place.
SECRETS_MASTER_KEY_HEX=

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=INFO
